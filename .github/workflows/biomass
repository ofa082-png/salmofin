name: Fetch Biomass
on:
  schedule:
    - cron: '0 6 21 * *'  # 21st each month at 6am UTC (day after update)
  workflow_dispatch:
jobs:
  fetch:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'
      - name: Install dependencies
        run: pip install requests pandas google-cloud-bigquery db-dtypes
      - name: Run fetch_biomass.py
        env:
          GOOGLE_CREDENTIALS: ${{ secrets.GOOGLE_CREDENTIALS }}
        run: python fetch_biomass.py
